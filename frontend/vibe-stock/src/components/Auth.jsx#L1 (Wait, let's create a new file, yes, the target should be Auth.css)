/* Auth Screen Container with Deep Slate/Navy Background */
.auth-container {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  width: 100vw;
  background-color: #0b0f19;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  overflow: hidden;
  color: #f3f4f6;
  margin: 0;
  padding: 20px;
  box-sizing: border-box;
}

/* Glowing background blobs */
.auth-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.15;
  pointer-events: none;
  z-index: 1;
}

.auth-glow--primary {
  top: 20%;
  left: 25%;
  width: 300px;
  height: 300px;
  background: radial-gradient(circle, #6366f1 0%, transparent 70%);
}

.auth-glow--secondary {
  bottom: 20%;
  right: 25%;
  width: 350px;
  height: 350px;
  background: radial-gradient(circle, #14b8a6 0%, transparent 70%);
}

/* Glassmorphism Auth Card */
.auth-card {
  position: relative;
  width: 100%;
  max-width: 440px;
  background: rgba(17, 24, 39, 0.7);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 24px;
  padding: 40px 32px;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  z-index: 10;
  box-sizing: border-box;
  animation: cardAppear 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes cardAppear {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Brand logo and titles */
.auth-card__brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-bottom: 28px;
}

.auth-card__logo {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  background: linear-gradient(135deg, #6366f1, #14b8a6);
  border-radius: 12px;
  font-weight: 800;
  font-size: 20px;
  color: #ffffff;
  margin-bottom: 12px;
  box-shadow: 0 8px 20px rgba(99, 102, 241, 0.3);
}

.auth-card__title {
  font-size: 24px;
  font-weight: 800;
  letter-spacing: -0.5px;
  margin: 0;
  background: linear-gradient(to right, #ffffff, #d1d5db);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.auth-card__subtitle {
  font-size: 13px;
  color: #9ca3af;
  margin: 6px 0 0 0;
}

/* Headings */
.auth-card__heading {
  font-size: 20px;
  font-weight: 700;
  margin-top: 0;
  margin-bottom: 20px;
  color: #ffffff;
  text-align: left;
}

/* Error message styling */
.auth-card__error {
  background: rgba(239, 68, 68, 0.15);
  border: 1px solid rgba(239, 68, 68, 0.3);
  color: #f87171;
  font-size: 13px;
  padding: 12px 16px;
  border-radius: 12px;
  margin-bottom: 20px;
  line-height: 1.4;
  animation: shake 0.4s ease;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-4px); }
  75% { transform: translateX(4px); }
}

/* Form Styles */
.auth-form {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.auth-form__group {
  display: flex;
  flex-direction: column;
  gap: 8px;
  text-align: left;
}

.auth-form__label {
  font-size: 13px;
  font-weight: 600;
  color: #d1d5db;
}

.auth-form__input {
  width: 100%;
  background: rgba(31, 41, 55, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  padding: 14px 16px;
  font-size: 15px;
  color: #ffffff;
  transition: all 0.2s ease;
  outline: none;
  box-sizing: border-box;
}

.auth-form__input::placeholder {
  color: #6b7280;
}

.auth-form__input:focus {
  border-color: #6366f1;
  background: rgba(31, 41, 55, 0.8);
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
}

.auth-form__submit {
  width: 100%;
  background: linear-gradient(90deg, #6366f1, #4f46e5);
  border: none;
  border-radius: 12px;
  padding: 15px;
  font-size: 15px;
  font-weight: 700;
  color: #ffffff;
  cursor: pointer;
  transition: all 0.2s ease;
  margin-top: 10px;
  box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
}

.auth-form__submit:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 6px 20px rgba(99, 102, 241, 0.4);
}

.auth-form__submit:active:not(:disabled) {
  transform: translateY(0);
}

.auth-form__submit:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

/* Card Mode Toggle */
.auth-card__toggle {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 24px;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  padding-top: 20px;
  gap: 6px;
}

.auth-card__toggle-text {
  font-size: 13px;
  color: #9ca3af;
  margin: 0;
}

.auth-card__toggle-btn {
  background: none;
  border: none;
  color: #14b8a6;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  padding: 4px 8px;
  transition: all 0.2s ease;
}

.auth-card__toggle-btn:hover {
  color: #2dd4bf;
  text-shadow: 0 0 8px rgba(20, 184, 166, 0.4);
}

/* Micro Animation: Fade In for confirm password field */
.animate-fade-in {
  animation: fadeIn 0.3s ease forwards;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
